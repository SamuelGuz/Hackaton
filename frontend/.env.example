# Backend FastAPI URL
VITE_API_URL=http://localhost:8000/api/v1

# Must match backend API_KEY (same string as in repo root .env). Sent as X-API-Key on each request.
# Without this, POST /accounts/import and other protected routes fail (401 or server config error).
VITE_API_KEY=

# Set to "true" to use local mock data instead of hitting the API
VITE_USE_MOCK=true
