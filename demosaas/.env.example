# Puedes poner estas lineas en Hackaton/.env (raiz del repo) o en demosaas/.env — Vite carga la raiz por defecto.
demo_saas_VITE_API_URL=https://backend.dark-army.lat/api/v1
demo_saas_VITE_API_KEY=demo-hackaton-2026

# Cuenta: el nombre se obtiene con GET /accounts/{demo_saas_VITE_ACCOUNT_ID}. El resto es opcional / fallback.
